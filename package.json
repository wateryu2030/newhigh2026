{
  "name": "newhigh",
  "private": true,
  "description": "Root npm scripts delegate to frontend/ (Next.js lives there, not repo root).",
  "scripts": {
    "dev": "npm run dev --prefix frontend",
    "dev:clean": "npm run dev:clean --prefix frontend",
    "dev:turbo": "npm run dev:turbo --prefix frontend",
    "build": "npm run build --prefix frontend",
    "start": "npm run start --prefix frontend",
    "lint": "npm run lint --prefix frontend"
  }
}

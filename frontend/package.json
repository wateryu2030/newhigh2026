{
  "name": "newhigh-frontend",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev -H 0.0.0.0 -p 3000",
    "dev:turbo": "next dev --turbo -H 0.0.0.0 -p 3000",
    "dev:brew": "env PATH=\"/opt/homebrew/bin:/usr/local/bin:$PATH\" next dev -H 0.0.0.0 -p 3000",
    "dev:clean": "rm -rf .next && mkdir -p .next/server && printf '%s\\n' '{\"version\":3,\"middleware\":{},\"functions\":{},\"sortedMiddleware\":[]}' > .next/server/middleware-manifest.json && next dev -H 0.0.0.0 -p 3000",
    "build": "next build",
    "build:clean": "rm -rf .next && next build",
    "start": "next start -H 0.0.0.0 -p 3000",
    "start:standalone": "bash scripts/run-standalone-server.sh",
    "lint": "next lint",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui"
  },
  "dependencies": {
    "@tanstack/react-query": "^5.17.0",
    "lightweight-charts": "^4.2.3",
    "next": "14.2.35",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "recharts": "^2.10.0",
    "zustand": "^4.4.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.40.0",
    "@types/node": "^20.0.0",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "autoprefixer": "^10.4.16",
    "postcss": "^8.4.32",
    "tailwindcss": "^3.3.6",
    "typescript": "^5.2.0"
  }
}

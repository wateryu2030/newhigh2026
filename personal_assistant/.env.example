# 个人量化投资助手 - 环境变量配置

# ===========================================
# DeepSeek AI（用于股票分析）
# ===========================================
# 获取地址：https://platform.deepseek.com/
DEEPSEEK_API_KEY=sk-your-api-key-here

# ===========================================
# Server 酱（用于微信推送）
# ===========================================
# 获取地址：https://sct.ftqq.com/
SERVERCHAN_SENDKEY=your-sendkey-here

# ===========================================
# SMTP 邮件（用于邮件推送）
# ===========================================
# 以 QQ 邮箱为例，其他邮箱请修改对应配置

# SMTP 服务器地址
SMTP_SERVER=smtp.qq.com

# SMTP 端口（587 或 465）
SMTP_PORT=587

# 邮箱用户名（完整邮箱地址）
SMTP_USERNAME=your-email@qq.com

# 邮箱授权码（不是登录密码！）
# 获取方法：QQ 邮箱 → 设置 → 账户 → 开启 SMTP 服务 → 获取授权码
SMTP_PASSWORD=your-auth-code-here

# 发件人地址（通常与用户名相同）
SMTP_FROM=your-email@qq.com

# 收件人地址（多个用逗号分隔）
SMTP_TO=receiver-email@qq.com

# ===========================================
# 其他配置
# ===========================================
# 数据库路径（一般不需要修改）
QUANT_SYSTEM_DUCKDB_PATH=/Users/apple/Ahope/newhigh/data/quant_system.duckdb

# 前端新闻页完整 URL（推送/通知中的「查看新闻」链接必须带 https://，否则点击可能打不开）
# 详见 docs/NOTIFICATION_LINKS.md
# FRONTEND_NEWS_URL=https://htma.newhigh.com.cn/news

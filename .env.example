# 红山量化 / newhigh 统一配置示例
# 复制为 .env 后按需修改，勿提交 .env 到版本库

# ---------- 数据库 ----------
# 统一 DuckDB 路径（data_pipeline、market_scanner、ai_models、strategy_engine、data_engine 共用）
QUANT_SYSTEM_DUCKDB_PATH=data/quant_system.duckdb
# 兼容旧变量名
# NEWHIGH_MARKET_DUCKDB_PATH=
# NEWHIGH_DUCKDB_PATH=

# ---------- Gateway / API ----------
API_HOST=0.0.0.0
API_PORT=8000
# API_RELOAD=true

# A 股 GET /api/market/klines：本地库无日线时是否用 akshare 东财兜底（默认 1）；代理不稳可设 0
# KLINE_FALLBACK_AKSHARE=1
# 非 A 股 K 线：行情页 BTCUSDT/ETHUSDT 走 Binance 公共接口；GOLD/SP500/NASDAQ 走 Stooq 日线 CSV（无需密钥）。
# 境外机若无法访问对应域名可设为 1 关闭（将返回空数据 / stub）
# BINANCE_KLINE_DISABLE=0
# STOOQ_KLINE_DISABLE=0

# 7 维情绪（默认：库内东财快照 → AkShare 东财现货 → Tushare 日 K；不启用新浪以保持来源一致）：
# SENTIMENT_7D_MIN_STOCKS=50
# SENTIMENT_7D_DAILY_FALLBACK=0  # 关闭日 K 降级
# SENTIMENT_7D_AKSHARE_ENABLE=1  # 东财现货；境外不通可改 0 并依赖日 K/update_realtime 链路
# SENTIMENT_7D_AKSHARE_TIMEOUT_SEC=25
# 拉东财前临时去掉 *proxy* 环境变量（默认 1，可消除本机坏 HTTPS 代理导致的 akshare_failed）
# SENTIMENT_7D_STRIP_PROXY=1
# SENTIMENT_7D_USE_SINA_SPOT=0  # 非默认：新浪 stock_zh_a_spot（一般不推荐）
# SENTIMENT_7D_SINA_TIMEOUT_SEC=120

# CORS：生产环境逗号分隔来源，勿用 *。未设置时默认 http://localhost:3000
# 公网主站示例（与 Next 来源一致，浏览器直连 Gateway 时用）
# CORS_ORIGINS=https://htma.newhigh.com.cn,http://localhost:3000

# JWT：生产建议 JWT_AUTH_REQUIRED=1，并设置强密钥（二选一变量名均可）
# JWT_AUTH_REQUIRED=1
# JWT_SECRET_KEY=请替换为长随机串
# JWT_SECRET=与 JWT_SECRET_KEY 等价，任选其一
# JWT_EXPIRE_MINUTES=60

# ---------- 政策采集 SQLite（主站 /news 「政策采集」Tab 经 Gateway 读取）----------
# 默认：integrations/hongshan/policy-news/sqlite/news.db（相对仓库根）
# POLICY_NEWS_DB_PATH=/abs/path/to/news.db

# ---------- 前端 → Gateway（Next） ----------
# 浏览器同源 /api 由 Next 服务端转发；**生产务必设置**（与 Gateway 同机可用 127.0.0.1，否则填内网/本机 Gateway 地址）
# API_PROXY_TARGET=http://127.0.0.1:8000
# 可选：仅客户端直连完整 API 根时内联到 JS（一般留空走同源 /api 即可）
# NEXT_PUBLIC_API_TARGET=http://127.0.0.1:8000

# ---------- Celery + Redis（可选，阶段 0.1 启用任务队列时） ----------
# CELERY_BROKER_URL=redis://127.0.0.1:6379/0
# CELERY_RESULT_BACKEND=redis://127.0.0.1:6379/0

# ---------- 执行层（阶段 3.2 实盘/模拟盘开关） ----------
# EXECUTION_MODE=simulated
# EXECUTION_MODE=live

# ---------- 数据源：Tushare（tushare_daily + OpenClaw A股 Skill 共用） ----------
# 获取 Token：https://tushare.pro/user/token
# Gateway 与 scripts/backfill_a_stock_daily.py 会自动加载本文件（勿把占位符提交进库）
# 兼容别名（任选其一即可，脚本会识别）：TUSHARE_TOKEN / TUSHARE_API_KEY / TS_TOKEN
TUSHARE_TOKEN=你的tushare_token

# Tushare API 配置
# 请求间隔（秒），避免频率限制
TUSHARE_REQUEST_INTERVAL=1
# 最大重试次数
TUSHARE_MAX_RETRIES=3
# 数据缓存目录
TUSHARE_CACHE_DIR=/tmp/tushare_cache
# 启用数据缓存（true/false）
TUSHARE_ENABLE_CACHE=true
# 缓存过期时间（小时）
TUSHARE_CACHE_TTL=24

# 每日调度（scripts/start_schedulers.py 18:00）：有 TUSHARE_TOKEN 时默认用 Tushare 拉近 N 天全市场日 K（建议保持较小，如 5–14）
# 深度历史/全市场回补请用 scripts/backfill_a_stock_daily.py 按需跑，勿把本值拉满代替回补
# TUSHARE_DAILY_DAYS_BACK=7
# 有 Token 时 akshare 批量日 K 默认关闭；需东财补少量标的时设为 20–100
# DAILY_AKSHARE_KLINE_LIMIT=0

# 每日调度跑完日 K/新闻后：是否执行 scripts/push_shareholder_chip_signals.py（仅写入 strategy_id=shareholder_chip）
# NEWHIGH_PUSH_SHAREHOLDER_CHIP_SIGNALS=1

# ---------- 妙想 / 东财自然语言查数（Cursor Skill「mx-data」、非常驻服务，按需 HTTPS 调用） ----------
# 在妙想 Skills 页获取 apikey；未设置时 Skill 无法代你调 mkapi2.dfcfs.com
# MX_APIKEY=

# 与 lib.database 一致的可选路径（见 data_pipeline duckdb_manager）
# QUANT_DB_PATH=
# NEWHIGH_DB_PATH=

# ---------- 百练 / 通义（OpenClaw LLM 策略生成、AI 开发代理） ----------
# 百练专属 API Key（阿里云百炼平台）；若使用 dashscope SDK 则变量名为 DASHSCOPE_API_KEY，可与此值一致
# BAILIAN_API_KEY=sk-sp-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ---------- OpenClaw 网关（货盘比价 /tools/invoke、脚本调用时必填） ----------
# OPENCLAW_GATEWAY_URL=http://127.0.0.1:18789
# OPENCLAW_GATEWAY_TOKEN=你的gateway_token

# ---------- mynewhigh（可选） ----------
# MYNEWHIGH_API_KEY=sk-xxx

# ---------- 数据质量巡检 / 告警（可选） ----------
# COVERAGE_ALERT_THRESHOLD=90
# DATA_QUALITY_WEBHOOK_URL=https://your-dingtalk-or-wework-webhook
# AUTO_BACKFILL=1

# ---------- 健康检查阈值（可选） ----------
# HEALTH_TOP10_MIN_ROWS=1000
# HEALTH_BASIC_MIN_ROWS=100
# CLICKHOUSE_URL=http://127.0.0.1:8123

# ---------- 日志（阶段 2.5：JSON 便于 Filebeat/Loki） ----------
# LOG_LEVEL=INFO
# LOG_JSON=true
